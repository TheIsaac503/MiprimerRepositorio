Algoritmo Suma_Y_Resta
	Definir numer1, numer2, suma, resta Como Entero;
	
	Escribir "Ingrese el primer número:";
	Leer numer1;
	
	Escribir "Ingrese el segundo número:";
	Leer numer2;
	
	suma = numer1 + numer2;
	resta = numer1 - numer2;
	
	Escribir "La suma es: ", suma;
	Escribir "La resta es: ", resta;
	
FinAlgoritmo